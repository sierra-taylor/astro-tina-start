---
const {data} = Astro.props
---
<div class="flex flex-col items-center gap-8 my-6">
    <h1 class="font-bold text-3xl self-center">{data.header}</h1>

    <!-- Team -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-20">
        <!-- Member -->
        {
            data.members.map((teamMember:any) => {
                return (
        <div class="flex gap-4">
            <!-- Photo -->
            <img alt="Logo" src={`${teamMember.avatar}`} class="rounded-full w-24" />

            <div class="flex flex-col gap-2">
                <!-- Name -->
                <h3 class="font-bold">{teamMember.name}</h3>

                <!-- Role -->
                <span class="text-sm">{teamMember.position}</span>

                <!-- Socials -->
                <div class="flex text-accent text-xs">
                    <a class="btn btn-ghost btn-sm btn-circle">
                        <i class="fa-brands fa-github text-lg"></i>
                    </a>

                    <a class="btn btn-ghost btn-sm btn-circle">
                        <i class="fa-brands fa-twitter text-lg"></i>
                    </a>

                    <a class="btn btn-ghost btn-sm btn-circle">
                        <i class="fa-brands fa-facebook text-lg"></i>
                    </a>
                </div>
            </div>
        </div>                    
                )
            })
        }

    </div>
</div>