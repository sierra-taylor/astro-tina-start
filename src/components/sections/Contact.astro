---
// import type { ContactSection } from "../../types/sections";

const { data } = Astro.props;
---

<div class="hero bg-base-200 min-h-screen">
  <div
    class="hero-content flex-col lg:flex-row w-full content-between justify-evenly"
  >
    <div class="card bg-base-100 w-full max-w-sm shrink-0 shadow-2xl">
      <div class="card-body">
        <div class="items-center">
          <h4 class="card-title text-3xl">{data.header}</h4>
          <p>{data.description}</p>
        </div>
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/"
          class="flex flex-col gap-5"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden" aria-hidden="true">
            <label
              >Leave this empty: <input
                name="bot-field"
                tabindex="-1"
                autocomplete="off"
              /></label
            >
          </p>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text"
              >Name <span class="text-accent" aria-hidden="true">*</span></span
            >
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text"
              >Email <span class="text-accent" aria-hidden="true">*</span></span
            >
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Phone</span>
            <input
              type="tel"
              name="phone"
              autocomplete="tel"
              inputmode="tel"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text"
              >Message <span class="text-accent" aria-hidden="true">*</span
              ></span
            >
            <textarea
              name="message"
              rows="5"
              required
              class="min-h-[120px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-y"
            ></textarea>
          </label>

          <button
            type="submit"
            class="mt-2 inline-flex min-h-[44px] cursor-pointer items-center justify-center self-start rounded-md bg-accent px-8 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            {data.buttonText}
          </button>
        </form>
      </div>
    </div>

    <div class="mx-2 text-xl text-center lg:text-right">
      {data.email && <p>{data.email}</p>}
      {data.phone && <a href="">{data.phone}</a>}
      {data.address && <p>{data.address}</p>}
    </div>
  </div>
</div>
